# Quick-reference SKU cards must be readable on shift with poor signal.
# Cache the built static assets aggressively; the SPA shell stays fresh.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Bottle images for the on-shift SKU cards: cache hard so they stay available.
/bottles/*
  Cache-Control: public, max-age=31536000, immutable

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
